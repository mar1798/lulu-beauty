# Base URL of your WordPress backend (used for public API requests)
NEXT_PUBLIC_WP_BASE_URL=

# Public URL of your frontend app (e.g., https://lulubeauty.com)
NEXT_PUBLIC_APP_URL=

# reCAPTCHA v3 site key used on the client side
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# Google Tag Manager container ID (e.g., GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=

# Google Analytics / Universal Analytics ID
NEXT_PUBLIC_UA_ID=

# A fallback base URL for server-side requests when others are undefined
FALLBACK_BASE_URL=
