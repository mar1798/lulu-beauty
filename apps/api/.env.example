# Local (non-Docker) defaults. Copy to .env: cp .env.example .env
PORT=3001
NODE_ENV=development

# For local `npm run dev -w api` against the Postgres container exposed on the host, use localhost.
# Inside docker-compose, the api service overrides this to use the `db` hostname instead.
DATABASE_URL=postgresql://lulu:lulu@localhost:5432/lulu?schema=public

# Used by the docker-compose `db` service to initialize Postgres.
POSTGRES_USER=lulu
POSTGRES_PASSWORD=lulu
POSTGRES_DB=lulu
